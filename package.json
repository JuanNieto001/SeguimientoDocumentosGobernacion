{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "playwright test --ui",
        "test:headed": "playwright test --headed",
        "test:run": "playwright test",
        "test:ui:demo": "set PW_DEMO_MODE=1&& set PW_SLOWMO_MS=700&& playwright test --ui --project=chromium",
        "test:run:demo": "set PW_DEMO_MODE=1&& set PW_SLOWMO_MS=700&& playwright test --project=chromium --headed --retries=0",
        "test:motor:demo": "set PW_DEMO_MODE=1&& set PW_SLOWMO_MS=700&& playwright test tests/motor-flujos --project=chromium --headed --retries=0",
        "test:debug": "playwright test --debug",
        "test:auth": "playwright test tests/auth",
        "test:dashboard": "playwright test tests/dashboard",
        "test:workflow": "playwright test tests/workflow",
        "test:chromium": "playwright test --project=chromium",
        "test:firefox": "playwright test --project=firefox",
        "test:mobile": "playwright test --project='Mobile Chrome'",
        "test:auth-ui": "playwright test tests/e2e/auth-casos-ui.spec.js --project=chromium --headed --retries=0",
        "test:auth-video-completo": "set AUTH_MANUAL_HOLD_MS=0&& playwright test tests/e2e/auth-casos-ui.spec.js --project=chromium --headed --retries=0 -g \"AUTH-000\"",
        "test:auth-video-manual": "set AUTH_MANUAL_HOLD_MS=900000&& set VIDEO_STEP_PAUSE_MS=1200&& playwright test tests/e2e/auth-casos-ui.spec.js --project=chromium --headed --retries=0 --timeout=1200000 -g \"AUTH-000\"",
        "test:flujo-ui": "playwright test tests/e2e/flujo-ui-desde-cero.spec.js --project=chromium --headed --retries=0",
        "test:casos-ui": "playwright test tests/e2e/auth-casos-ui.spec.js tests/e2e/flujo-ui-desde-cero.spec.js --project=chromium --headed --retries=0",
        "test:auth-final-reset": "playwright test tests/e2e/zzz-auth-reset-final.spec.js --project=chromium --headed --retries=0",
        "test:casos-ui-con-reset-final": "playwright test tests/e2e/auth-casos-ui.spec.js tests/e2e/flujo-ui-desde-cero.spec.js tests/e2e/zzz-auth-reset-final.spec.js --project=chromium --headed --retries=0",
        "test:report": "playwright show-report",
        "test:setup": "php artisan migrate:refresh && php artisan db:seed --class=TestingSeederStructure",
        "test:full": "npm run test:setup && playwright test"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.1.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "typescript": "^5.3.3",
        "vite": "^7.3.2"
    },
    "dependencies": {
        "@vitejs/plugin-react": "^5.1.4",
        "@xyflow/react": "^12.10.1",
        "gridstack": "^12.6.0",
        "react": "^19.2.4",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "^19.2.4",
        "react-grid-layout": "^1.4.4",
        "react-resizable": "^3.1.3",
        "recharts": "^2.12.7"
    }
}
