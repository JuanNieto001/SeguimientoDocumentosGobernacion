{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "cypress open",
        "test:headless": "cypress run",
        "test:ci": "cypress run --browser chrome --headless --record false --parallel false",
        "test:mobile": "cypress run --config viewportWidth=375,viewportHeight=667",
        "test:desktop": "cypress run --config viewportWidth=1920,viewportHeight=1080",
        "test:auth": "cypress run --spec 'cypress/e2e/01-authentication/**'",
        "test:dashboard": "cypress run --spec 'cypress/e2e/02-dashboard/**'",
        "test:cdpn": "cypress run --spec 'cypress/e2e/03-flujo-cdpn/**'",
        "test:smoke": "cypress run --spec 'cypress/e2e/01-authentication/login.cy.js,cypress/e2e/02-dashboard/dashboard-interactivo.cy.js'",
        "test:reports": "cypress run --reporter cypress-multi-reporters",
        "test:setup": "php artisan migrate:refresh && php artisan db:seed --class=TestingSeederStructure",
        "test:full": "npm run test:setup && npm run test:headless"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7",
        "cypress": "^13.7.0",
        "@cypress/webpack-preprocessor": "^6.0.1",
        "cypress-file-upload": "^5.0.8",
        "cypress-drag-drop": "^1.1.1",
        "cypress-real-events": "^1.11.0",
        "cypress-multi-reporters": "^1.6.4",
        "mochawesome": "^7.1.3",
        "mochawesome-merge": "^4.3.0",
        "mochawesome-report-generator": "^6.2.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "@vitejs/plugin-react": "^5.1.4",
        "@xyflow/react": "^12.10.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}
