{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "playwright test --ui",
        "test:headed": "playwright test --headed",
        "test:run": "playwright test",
        "test:debug": "playwright test --debug",
        "test:auth": "playwright test tests/auth",
        "test:dashboard": "playwright test tests/dashboard",
        "test:workflow": "playwright test tests/workflow",
        "test:chromium": "playwright test --project=chromium",
        "test:firefox": "playwright test --project=firefox",
        "test:mobile": "playwright test --project='Mobile Chrome'",
        "test:report": "playwright show-report",
        "test:setup": "php artisan migrate:refresh && php artisan db:seed --class=TestingSeederStructure",
        "test:full": "npm run test:setup && playwright test"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.1.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "typescript": "^5.3.3",
        "vite": "^7.3.2"
    },
    "dependencies": {
        "@vitejs/plugin-react": "^5.1.4",
        "@xyflow/react": "^12.10.1",
        "react": "^19.2.4",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "^19.2.4",
        "react-grid-layout": "^1.4.4",
        "react-resizable": "^3.1.3",
        "recharts": "^2.12.7"
    }
}
