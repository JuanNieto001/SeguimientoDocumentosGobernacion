{
  "api_endpoints": {
    "auth": {
      "login": "/api/auth/login",
      "logout": "/api/auth/logout",
      "me": "/api/auth/me"
    },
    "users": {
      "index": "/api/users",
      "store": "/api/users",
      "show": "/api/users/{id}",
      "update": "/api/users/{id}",
      "destroy": "/api/users/{id}"
    },
    "processes": {
      "index": "/api/procesos",
      "store": "/api/procesos",
      "show": "/api/procesos/{id}",
      "update": "/api/procesos/{id}",
      "advance": "/api/procesos/{id}/advance-stage",
      "documents": "/api/procesos/{id}/documents"
    },
    "dashboard": {
      "config": "/api/dashboard/config",
      "data": "/api/dashboard/data",
      "widgets": "/api/dashboard/widgets",
      "save_layout": "/api/dashboard/save-layout"
    },
    "workflows": {
      "index": "/api/workflows",
      "show": "/api/workflows/{id}",
      "stages": "/api/workflows/{id}/stages"
    }
  },
  "selectors": {
    "auth": {
      "email_input": "[data-cy='email-input']",
      "password_input": "[data-cy='password-input']",
      "login_button": "[data-cy='login-button']",
      "logout_button": "[data-cy='logout-button']",
      "user_menu": "[data-cy='user-menu-button']"
    },
    "navigation": {
      "dashboard_link": "[data-cy='nav-dashboard']",
      "processes_link": "[data-cy='nav-processes']",
      "users_link": "[data-cy='nav-users']",
      "reports_link": "[data-cy='nav-reports']"
    },
    "dashboard": {
      "container": "[data-cy='dashboard-container']",
      "widget_presupuesto": "[data-cy='widget-presupuesto-total']",
      "widget_procesos": "[data-cy='widget-procesos-globales']",
      "filters_panel": "[data-cy='filters-panel']",
      "apply_filters": "[data-cy='apply-filters-btn']"
    },
    "process": {
      "create_button": "[data-cy='crear-proceso-btn']",
      "process_form": "[data-cy='proceso-form']",
      "codigo_input": "[data-cy='codigo-input']",
      "objeto_input": "[data-cy='objeto-input']",
      "valor_input": "[data-cy='valor-input']",
      "advance_stage": "[data-cy='avanzar-etapa-btn']",
      "stage_indicator": "[data-cy='stage-indicator']"
    },
    "documents": {
      "upload_area": "[data-cy='document-upload-area']",
      "file_input": "[data-cy='file-input']",
      "upload_button": "[data-cy='upload-button']",
      "document_list": "[data-cy='document-list']"
    }
  },
  "test_timeouts": {
    "short": 5000,
    "medium": 10000,
    "long": 15000,
    "upload": 30000,
    "api_call": 10000,
    "page_load": 15000
  },
  "test_data_limits": {
    "max_file_size": 5242880,
    "allowed_formats": ["pdf", "doc", "docx", "xls", "xlsx"],
    "max_processes_per_test": 5,
    "max_documents_per_stage": 10
  },
  "validation_messages": {
    "login": {
      "success": "Inicio de sesión exitoso",
      "invalid_credentials": "Las credenciales proporcionadas no coinciden",
      "required_fields": "Todos los campos son obligatorios"
    },
    "process": {
      "created": "Proceso creado exitosamente",
      "updated": "Proceso actualizado correctamente",
      "stage_advanced": "Proceso avanzado a la siguiente etapa",
      "validation_error": "Por favor complete todos los campos requeridos"
    },
    "documents": {
      "upload_success": "Documento cargado exitosamente",
      "invalid_format": "Formato de archivo no válido",
      "file_too_large": "El archivo excede el tamaño máximo permitido"
    }
  },
  "performance_thresholds": {
    "page_load_time": 3000,
    "api_response_time": 1000,
    "file_upload_time": 10000,
    "dashboard_render_time": 2000
  },
  "browser_configurations": {
    "chrome": {
      "width": 1366,
      "height": 768,
      "user_agent": "Cypress Testing Chrome"
    },
    "mobile_chrome": {
      "width": 375,
      "height": 667,
      "user_agent": "Cypress Testing Mobile"
    }
  },
  "test_scenarios": {
    "smoke_tests": [
      "login_successful",
      "dashboard_loads",
      "navigation_works",
      "logout_successful"
    ],
    "critical_path": [
      "create_process",
      "upload_documents",
      "advance_all_stages",
      "complete_process"
    ],
    "regression_tests": [
      "all_user_roles",
      "all_process_types",
      "all_document_formats",
      "responsive_layouts"
    ]
  },
  "ci_configuration": {
    "parallel_runs": 4,
    "retry_attempts": 2,
    "record_video": false,
    "save_screenshots": true,
    "browser": "chrome",
    "headless": true
  }
}